# Supabase — https://app.supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...          # public anon key (safe for client)
SUPABASE_SERVICE_KEY=eyJ...       # service role key (server only, never expose)

PORT=3001

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...         # or sk_test_... for dev
STRIPE_WEBHOOK_SECRET=whsec_...       # from Stripe CLI: stripe listen --forward-to localhost:3001/v1/stripe/webhook
STRIPE_PRICE_PRO_MONTHLY=price_...    # $7/month recurring (create in Stripe Dashboard)
STRIPE_PRICE_API_METERED=price_...    # pay-as-you-go for B2B devs

# App public URL (used for Stripe redirects)
APP_URL=https://pith.app

# ML cron job (SaaS auto-evolution from DB signals)
ML_CRON_ENABLED=false
ML_CRON_INTERVAL_MS=3600000
ML_CRON_AUTO_PROMOTE=false

# AES-256-GCM for ml_samples / ml_feedback_events at rest (64 hex chars = 32 bytes). Required for encrypted rows.
# ML_ENCRYPTION_KEY=
