{
  "name": "pith-vscode",
  "displayName": "Pith",
  "description": "Zero-G prompt compressor and distiller for LLMs",
  "version": "2.2.0",
  "publisher": "angelo-castro",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pith.optimize",
        "title": "Pith: Optimize Selected Text"
      }
    ],
    "chatParticipants": [
      {
        "id": "pith.assistant",
        "name": "pith",
        "fullName": "Pith Compressor",
        "description": "Zero-G prompt compressor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build": "npm run package",
    "vscode:package": "vsce package"
  },
  "dependencies": {
    "@pith/core": "*"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.4.5"
  }
}
