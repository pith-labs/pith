{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "outDir": "out",
    "lib": [
      "ES2022"
    ],
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node", "vscode"],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "../src/core/PithEngine.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
