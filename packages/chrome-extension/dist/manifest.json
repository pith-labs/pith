{
  "manifest_version": 3,
  "name": "PITH",
  "version": "2.1.0",
  "description": "PITH - Invisible AI Prompt Compressor. Remove noise, save tokens.",
  "permissions": [
    "storage",
    "identity",
    "tabs"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "PITH Dashboard"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-CldqL7Er.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*",
        "https://you.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-pith": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle PITH on/off"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "https://gemini.google.com/*",
        "https://poe.com/*",
        "https://www.perplexity.ai/*",
        "https://you.com/*"
      ],
      "resources": [
        "assets/PithEngine-BnfxNDYW.js",
        "assets/content.ts-DChKTwVy.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
