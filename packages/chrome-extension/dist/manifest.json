{
  "manifest_version": 3,
  "name": "PITH",
  "key": "",
  "version": "2.1.0",
  "description": "PITH - Invisible AI Prompt Compressor. Remove noise, save tokens.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://pith.onrender.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "PITH Dashboard"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-C4kAk-wK.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*",
        "https://you.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-pith": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle PITH on/off"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "https://gemini.google.com/*",
        "https://poe.com/*",
        "https://www.perplexity.ai/*",
        "https://you.com/*"
      ],
      "resources": [
        "assets/PithEngine-BnfxNDYW.js",
        "assets/content.ts-Bw5NBWq9.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
