{
  "manifest_version": 3,
  "name": "PITH",
  "key": "",
  "version": "2.1.0",
  "description": "PITH - Invisible AI Prompt Compressor. Remove noise, save tokens.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "PITH Dashboard"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*",
        "https://you.com/*"
      ],
      "js": ["src/content/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-pith": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle PITH on/off"
    }
  }
}
